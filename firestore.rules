rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Products: anyone can read, only authenticated admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Site content: anyone can read, only authenticated admin can write
    match /siteContent/{section} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Stores: anyone can read, only authenticated admin can write
    match /stores/{storeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Spots: anyone can read, only authenticated admin can write
    match /spots/{spotId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Events: anyone can read, only authenticated admin can write
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Spot stats: admin can read, anyone can increment counters (aggregate only, no PII)
    match /spotStats/{spotId} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // Contacts: anyone can create, only authenticated admin can read
    match /contacts/{contactId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message', 'createdAt', 'updatedAt'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
