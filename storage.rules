rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Hero image: public read, auth-only write
    match /hero/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Story image: public read, auth-only write
    match /story/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Spot images: public read, auth-only write
    match /spots/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Product images: public read, auth-only write
    match /products/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
